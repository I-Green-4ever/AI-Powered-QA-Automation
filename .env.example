# Didaxis Studio (UI tests)
DIDAXIS_URL=https://didaxis.studio
DIDAXIS_EMAIL=your-admin@example.com
DIDAXIS_PASSWORD=your-password

# API token for post-run cleanup (DELETE /api/programs/:id)
DIDAXIS_API_TOKEN=dt_your_api_token_here

# Set to 1 to skip API DELETE teardown (per-test + global)
# SKIP_API_CLEANUP=1
